# ─── CCGC Environment Variables ────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.
#
# ────────────────────────────────────────────────────────────────────────────


# ── Calendly Scheduling ─────────────────────────────────────────────────────
#
# Your Calendly event URL. Once set, the /book page will render a live
# inline scheduling widget instead of the placeholder.
#
# After setting this variable:
#   1. Install react-calendly:  npm install react-calendly
#   2. Open components/CalendlyEmbed.tsx and uncomment the InlineWidget import
#      and usage (clearly marked with comments inside the file).
#
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/YOUR_HANDLE/intro


# ── Contact Form Backend ─────────────────────────────────────────────────────
#
# Both forms (QualificationForm on /book, ContactForm on /contact) currently
# simulate submission with a 1-second delay. Wire them to a real backend by:
#
# Option A — Resend (recommended):
#   RESEND_API_KEY=re_...
#   CONTACT_FORM_TO=info@ccgc.us
#
# Option B — Formspree:
#   NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
#
# Option C — Custom API route at app/api/contact/route.ts
#   No env vars needed — implement the handler directly.
